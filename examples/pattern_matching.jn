type Option a = Some a | None

# Pattern matching with exhaustiveness checking
let unwrapOr = (opt, fallback) ->
  match opt with
  | Some(x) -> x
  | None -> fallback
  end

# Pipe operator for functional composition
let result = Some(10)
  |> (opt) -> unwrapOr(opt, 0)
  |> (x) -> x * 2
  |> intToString
  |> print
