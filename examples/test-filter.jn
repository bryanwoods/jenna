type List a = Cons a List a | Nil

let filter = (lst, pred) ->
  match lst with
  | Nil -> Nil
  | Cons(h, t) -> if pred(h) then Cons(h, filter(t, pred)) else filter(t, pred)
  end

let sum = (lst) ->
  match lst with
  | Nil -> 0
  | Cons(h, t) -> h + sum(t)
  end

let isEven = (x) -> x - x / 2 * 2 == 0

let test1 = isEven(2)
let test2 = isEven(3)
let test3 = isEven(4)

let msg1 = print("isEven(2):")
let out1 = print(test1)
let msg2 = print("isEven(3):")
let out2 = print(test2)
let msg3 = print("isEven(4):")
let out3 = print(test3)

let numbers = Cons(1, Cons(2, Cons(3, Cons(4, Cons(5, Nil)))))
let evens = filter(numbers, isEven)
let evensSum = sum(evens)

let msg4 = print("Sum of evens:")
let out4 = print(evensSum)
