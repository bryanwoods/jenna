# Test modulo operator

# Test 1: 10 % 3 = 1
let test1 = 10 % 3
let check1 = if test1 == 1 then print("✓ 10 % 3 = 1") else print("✗ Test 1 failed")

# Test 2: 15 % 5 = 0
let test2 = 15 % 5
let check2 = if test2 == 0 then print("✓ 15 % 5 = 0") else print("✗ Test 2 failed")

# Test 3: 7 % 2 = 1
let test3 = 7 % 2
let check3 = if test3 == 1 then print("✓ 7 % 2 = 1") else print("✗ Test 3 failed")

# Test 4: 100 % 10 = 0
let test4 = 100 % 10
let check4 = if test4 == 0 then print("✓ 100 % 10 = 0") else print("✗ Test 4 failed")

# Test 5: Expression (6 + 4) % 3 = 1
let test5 = (6 + 4) % 3
let check5 = if test5 == 1 then print("✓ (6 + 4) % 3 = 1") else print("✗ Test 5 failed")

let final = print("=== Modulo operator tests complete! ===")
