# Testing Option type with pattern matching

# Define Option type
type Option a = Some a | None

# Create some values
let x = Some(42)
let y = None

# Pattern match on Option
let unwrap = (opt) ->
  match opt with
  | Some(value) -> value
  | None -> 0
  end

# Test with Some
let result1 = unwrap(x)
let msg1 = print("unwrap(Some(42)) = 42")

# Test with None
let result2 = unwrap(y)
let msg2 = print("unwrap(None) = 0")
