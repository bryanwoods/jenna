# Test pipe operator |>

# Test 1: Simple pipe - 5 |> double
let double = (x) -> x * 2
let test1 = 5 |> double
let check1 = if test1 == 10 then print("✓ 5 |> double = 10") else print("✗ Test 1 failed")

# Test 2: Pipe chain - 3 |> double |> double
let test2 = 3 |> double |> double
let check2 = if test2 == 12 then print("✓ 3 |> double |> double = 12") else print("✗ Test 2 failed")

# Test 3: Pipe with lambda
let test3 = 10 |> ((x) -> x + 5)
let check3 = if test3 == 15 then print("✓ 10 |> ((x) -> x + 5) = 15") else print("✗ Test 3 failed")

# Test 4: Pipe with increment
let increment = (x) -> x + 1
let test4 = 0 |> increment |> increment |> increment
let check4 = if test4 == 3 then print("✓ 0 |> increment |> increment |> increment = 3") else print("✗ Test 4 failed")

# Test 5: Pipe with functions that return strings
let intToStr = (n) -> intToString(n)
let test5 = 42 |> intToStr
let check5 = if test5 == "42" then print("✓ 42 |> intToStr = \"42\"") else print("✗ Test 5 failed")

# Test 6: Complex pipeline
let addTen = (x) -> x + 10
let multiplyByThree = (x) -> x * 3
let test6 = 5 |> addTen |> multiplyByThree
let check6 = if test6 == 45 then print("✓ 5 |> addTen |> multiplyByThree = 45") else print("✗ Test 6 failed")

# Test 7: Pipe with printInt (should print and return value)
let check7 = print("Testing pipe with printInt:")
let test7 = 100 |> printInt
let check8 = if test7 == 100 then print("✓ 100 |> printInt returns 100") else print("✗ Test 7 failed")

let final = print("=== Pipe operator tests complete! ===")
