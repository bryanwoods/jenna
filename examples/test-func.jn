# Test function evaluation
let testDiv = (x, n) -> (x - (x / n) * n)

let result1 = testDiv(7, 3)
let result2 = testDiv(15, 3)

let test1 = if result1 == 1 then print("testDiv(7, 3) = 1") else print("testDiv(7, 3) != 1")
let test2 = if result1 == 0 then print("testDiv(7, 3) = 0") else print("testDiv(7, 3) != 0")

let test3 = if result2 == 0 then print("testDiv(15, 3) = 0") else print("testDiv(15, 3) != 0")
