# Test divisibleBy function
let divisibleBy = (x, n) -> x - x / n * n == 0

let test1 = divisibleBy(15, 15)
let test2 = divisibleBy(15, 3)
let test3 = divisibleBy(15, 5)
let test4 = divisibleBy(7, 3)

let msg1 = if test1 then print("15 divisible by 15: true") else print("15 divisible by 15: false")
let msg2 = if test2 then print("15 divisible by 3: true") else print("15 divisible by 3: false")
let msg3 = if test3 then print("15 divisible by 5: true") else print("15 divisible by 5: false")
let msg4 = if test4 then print("7 divisible by 3: true") else print("7 divisible by 3: false")
